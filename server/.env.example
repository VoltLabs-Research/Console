# MongoDB connection string for identity store.
MONGO_URL=mongodb://localhost:27017/console_voltcloud

# RSA keypair for RS256-signed JWTs. PKCS#8 PEM for the private key, SPKI PEM for the public key.
# Generate with:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out jwt-private.pem
#   openssl pkey -in jwt-private.pem -pubout -out jwt-public.pem
# Then set the contents below (single-line, replace literal newlines with \n, or wrap in quotes preserving newlines).
JWT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n"

# Key ID advertised in JWKS and embedded in JWT headers.
JWT_KID=console-2026-06

# Shared bearer token used by the Registry service when calling /auth/introspect.
REGISTRY_SERVICE_TOKEN=dev-service-token

# Comma-separated list of allowed CORS origins.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://console.voltcloud.dev

# HTTP port.
PORT=8081
